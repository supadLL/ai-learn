{
  "name": "ai-play",
  "version": "1.0.3",
  "description": "AI 技术学习平台 - 从入门到深入的系统化学习工具",
  "author": "liangliang",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "npm run knowledge:build && npm run knowledge:check && npm run retrieval:check && npm run retrieval:runtime-check && tsc && vite build",
    "knowledge:build": "node scripts/build-knowledge-index.mjs",
    "knowledge:check": "node scripts/check-knowledge-index.mjs",
    "retrieval:check": "node scripts/check-retrieval-smoke.mjs",
    "retrieval:runtime-check": "node scripts/check-runtime-retrieval.mjs",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --publish never",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "rcedit": "^5.0.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.aiplay.app",
    "productName": "AI Play",
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/after-pack.cjs",
    "artifactName": "AI-Play-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "executableName": "AI Play",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "AI Play",
      "shortcutName": "AI Play",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
